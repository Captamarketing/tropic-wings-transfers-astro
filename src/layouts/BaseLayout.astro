---
export interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: object | object[];
  noindex?: boolean;
}

const {
  title,
  description,
  canonical,
  schema,
  noindex = false,
} = Astro.props;

const canonicalURL = canonical
  ? `https://transfers.tropicwings.com.au${canonical}`
  : `https://transfers.tropicwings.com.au${Astro.url.pathname}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    {noindex && <meta name="robots" content="noindex, follow" />}

    <!-- GEO -->
    <meta name="geo.region" content="AU-QLD" />
    <meta name="geo.placename" content="Cairns, Queensland, Australia" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Tropic Wings Transfers" />
    <meta property="og:image" content="https://transfers.tropicwings.com.au/og-image.jpg" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Manrope:wght@400;500;600&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries" is:inline></script>
    <script is:inline>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              "surface-dim": "#dadada",
              "outline": "#6e7980",
              "on-primary": "#ffffff",
              "on-primary-fixed-variant": "#004d66",
              "primary-container": "#22b1e5",
              "primary": "#006687",
              "surface-tint": "#006687",
              "on-primary-fixed": "#001e2b",
              "surface-bright": "#f9f9f9",
              "error": "#ba1a1a",
              "secondary-container": "#dfe924",
              "on-secondary-fixed": "#1b1d00",
              "surface-container-lowest": "#ffffff",
              "tertiary-container": "#d69a00",
              "secondary": "#5e6300",
              "on-secondary-container": "#626700",
              "on-primary-container": "#004056",
              "on-surface-variant": "#3e484f",
              "surface-variant": "#e2e2e2",
              "secondary-fixed": "#e2ec28",
              "primary-fixed": "#c1e8ff",
              "outline-variant": "#bdc8d0",
              "background": "#f9f9f9",
              "surface": "#f9f9f9",
              "inverse-on-surface": "#f1f1f1",
              "on-secondary": "#ffffff",
              "on-background": "#1a1c1c",
              "inverse-primary": "#72d2ff",
              "error-container": "#ffdad6",
              "on-surface": "#1a1c1c",
              "on-error": "#ffffff",
              "inverse-surface": "#2f3131",
              "surface-container-highest": "#e2e2e2",
              "surface-container-high": "#e8e8e8",
              "surface-container-low": "#f3f3f3",
              "surface-container": "#eeeeee",
            },
            borderRadius: {
              DEFAULT: "0.25rem",
              lg: "0.5rem",
              xl: "0.75rem",
              full: "9999px",
            },
            fontFamily: {
              headline: ["Plus Jakarta Sans"],
              body: ["Manrope"],
              label: ["Inter"],
            },
          },
        },
      };
    </script>

    <!-- Schema JSON-LD -->
    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(
        Array.isArray(schema)
          ? { "@context": "https://schema.org", "@graph": schema }
          : schema
      )} />
    )}

    <!-- Page-level head slot (for additional meta/schema) -->
    <slot name="head" />

    <style is:global>
      body {
        font-family: 'Manrope', sans-serif;
        background-color: #f9f9f9;
        color: #1a1c1c;
      }
      .font-headline { font-family: 'Plus Jakarta Sans', sans-serif; }
      .font-label { font-family: 'Inter', sans-serif; }
      .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      }
      .glass-panel {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
      }
      .action-pill-gradient {
        background: linear-gradient(135deg, #006687 0%, #22b1e5 100%);
      }
      .hero-clip {
        clip-path: polygon(0 0, 100% 0, 100% 88%, 0% 100%);
      }
    </style>
  </head>
  <body class="bg-surface text-on-surface selection:bg-secondary-container">

    <!-- Nav — replace with standard Tropic Wings nav component when ready -->
    <slot name="nav">
      <nav class="fixed top-0 w-full z-50 bg-white/90 backdrop-blur-md shadow-sm">
        <div class="flex justify-between items-center max-w-7xl mx-auto px-8 h-18 py-4">
          <!-- Logo -->
          <a href="/" class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg bg-primary flex items-center justify-center">
              <span class="material-symbols-outlined text-on-primary text-base" style="font-variation-settings:'FILL' 1;">flight</span>
            </div>
            <div>
              <p class="font-headline font-black text-primary text-base leading-tight">Tropic Wings</p>
              <p class="font-label text-[10px] uppercase tracking-widest text-on-surface-variant leading-tight">Transfers</p>
            </div>
          </a>
          <!-- Links -->
          <div class="hidden md:flex items-center gap-8 font-headline text-sm">
            <a href="/seat-in-coach" class="text-on-surface-variant hover:text-primary transition-colors">Seat in Coach</a>
            <a href="/private-transfer" class="text-on-surface-variant hover:text-primary transition-colors">Private Transfer</a>
            <a href="https://tropicwings.com.au" class="text-on-surface-variant hover:text-primary transition-colors">Day Tours</a>
          </div>
          <!-- CTA -->
          <a href="/transfers" class="action-pill-gradient text-on-primary px-6 py-2.5 rounded-full font-headline font-bold text-sm hover:scale-[1.02] transition-transform shadow-md">
            Book Now
          </a>
        </div>
      </nav>
      <!-- Spacer so content doesn't hide under fixed nav -->
      <div class="h-[66px]"></div>
    </slot>

    <main>
      <slot />
    </main>

    <slot name="footer">
      <!-- Default footer — override with named slot if needed -->
      <footer class="bg-slate-50 w-full py-12 border-t border-slate-200">
        <div class="flex flex-col md:flex-row justify-between items-center max-w-7xl mx-auto px-8 gap-6">
          <div class="flex flex-col items-center md:items-start gap-2">
            <div class="text-xl font-bold text-primary font-headline">Tropic Wings Transfers</div>
            <p class="text-sm text-slate-500 font-body">© {new Date().getFullYear()} Tropic Wings Cairns Tours &amp; Charters. All rights reserved.</p>
          </div>
          <div class="flex flex-wrap justify-center gap-8 text-sm text-slate-500">
            <a class="hover:text-primary transition-colors" href="/privacy">Privacy Policy</a>
            <a class="hover:text-primary transition-colors" href="/terms">Terms of Service</a>
            <a class="hover:text-primary transition-colors" href="https://tropicwings.com.au">Tropic Wings Main Site</a>
            <a class="hover:text-primary transition-colors" href="/contact">Contact</a>
          </div>
        </div>
      </footer>
    </slot>

  </body>
</html>
