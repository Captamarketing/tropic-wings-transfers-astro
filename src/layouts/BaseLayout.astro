---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: object | object[];
  noindex?: boolean;
}

const {
  title,
  description,
  canonical,
  schema,
  noindex = false,
} = Astro.props;

const canonicalURL = canonical
  ? `https://transfers.tropicwings.com.au${canonical}`
  : `https://transfers.tropicwings.com.au${Astro.url.pathname}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    {noindex && <meta name="robots" content="noindex, follow" />}

    <!-- GEO -->
    <meta name="geo.region" content="AU-QLD" />
    <meta name="geo.placename" content="Cairns, Queensland, Australia" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Tropic Wings Transfers" />
    <meta property="og:image" content="https://transfers.tropicwings.com.au/og-image.jpg" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Manrope:wght@400;500;600&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />

    <!-- Schema JSON-LD -->
    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(
        Array.isArray(schema)
          ? { "@context": "https://schema.org", "@graph": schema }
          : { "@context": "https://schema.org", ...schema }
      )} />
    )}

    <!-- Page-level head slot (for additional meta/schema) -->
    <slot name="head" />
  </head>
  <body class="bg-surface text-on-surface selection:bg-secondary-container">

    <slot name="nav">
      <style>
        .tw-nav {
          position: fixed; top: 0; left: 0; right: 0; z-index: 100;
          padding: 12px 24px;
          display: flex; justify-content: space-between; align-items: center;
          background: rgba(255,255,255,.97);
          box-shadow: 0 2px 20px rgba(0,0,0,.08);
          transition: background .3s, box-shadow .3s;
        }
        .tw-nav-logo img { height: 44px; }
        .tw-nav-links {
          display: flex; gap: 28px; align-items: center;
          list-style: none; margin: 0; padding: 0;
        }
        .tw-nav-links a {
          text-decoration: none; font-size: 14px; font-weight: 500;
          letter-spacing: .3px; color: #1a1a1a; transition: color .2s;
        }
        .tw-nav-links a:hover { color: #22a7df; }
        .tw-nav-cta {
          background: #d4de23; color: #1a1a1a;
          padding: 10px 22px; border-radius: 6px; font-weight: 700;
          font-size: 14px; text-decoration: none;
          transition: background .2s, transform .2s; display: inline-block;
        }
        .tw-nav-cta:hover { background: #c4ce13 !important; transform: translateY(-1px); color: #1a1a1a !important; }
        .tw-nav-mobile-toggle {
          display: none; background: none; border: none; cursor: pointer; padding: 4px;
        }
        .tw-nav-mobile-toggle span {
          display: block; width: 24px; height: 2px;
          background: #1a1a1a; margin: 5px 0;
        }
        .tw-mobile-overlay {
          position: fixed; inset: 0; background: rgba(0,0,0,.5); z-index: 199;
          opacity: 0; visibility: hidden; transition: opacity .3s, visibility .3s;
        }
        .tw-mobile-overlay.open { opacity: 1; visibility: visible; }
        .tw-mobile-nav {
          position: fixed; top: 0; right: -100%; width: 280px; height: 100vh;
          background: #1a1a1a; z-index: 200; padding: 80px 28px 28px;
          transition: right .35s ease; display: flex; flex-direction: column; gap: 4px;
        }
        .tw-mobile-nav.open { right: 0; }
        .tw-mobile-nav-close {
          position: absolute; top: 20px; right: 20px; background: none; border: none;
          color: white; font-size: 28px; cursor: pointer;
          width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;
        }
        .tw-mobile-nav a {
          display: block; padding: 12px 0; color: rgba(255,255,255,.8);
          text-decoration: none; font-size: 15px; font-weight: 500;
          border-bottom: 1px solid rgba(255,255,255,.08); transition: color .2s;
        }
        .tw-mobile-nav a:hover { color: white; }
        .tw-mobile-nav .tw-nav-cta {
          margin-bottom: 8px; text-align: center;
          padding: 14px 22px; border-radius: 8px; border-bottom: none !important;
        }
        @media (max-width: 768px) {
          .tw-nav-links { display: none; }
          .tw-nav-mobile-toggle { display: block; }
        }
      </style>

      <nav class="tw-nav">
        <a class="tw-nav-logo" href="/">
          <img src="https://tropicwings.com.au/wp-content/uploads/2022/08/Tropic-Wings-Logo-WEB.png" alt="Tropic Wings" />
        </a>
        <ul class="tw-nav-links">
          <li><a href="/seat-in-coach">Seat in Coach</a></li>
          <li><a href="/private-transfer">Private Transfer</a></li>
          <li><a href="https://tropicwings.com.au">Day Tours</a></li>
          <li><a href="/transfers" class="tw-nav-cta">Book Now</a></li>
        </ul>
        <button
          class="tw-nav-mobile-toggle"
          id="tw-nav-toggle"
          aria-label="Open menu"
          aria-controls="tw-mobile-nav"
          aria-expanded="false"
        >
          <span></span><span></span><span></span>
        </button>
      </nav>

      <div class="tw-mobile-overlay" id="tw-overlay" aria-hidden="true"></div>
      <div class="tw-mobile-nav" id="tw-mobile-nav" role="dialog" aria-modal="true" aria-label="Site menu">
        <button class="tw-mobile-nav-close" id="tw-nav-close" aria-label="Close menu">&times;</button>
        <a href="/transfers" class="tw-nav-cta">Book Now</a>
        <a href="/seat-in-coach">Seat in Coach</a>
        <a href="/private-transfer">Private Transfer</a>
        <a href="https://tropicwings.com.au">Day Tours</a>
        <a href="/contact">Contact</a>
      </div>

      <!-- Spacer so content doesn't hide under fixed nav -->
      <div style="height:68px"></div>

      <script>
        const toggle = document.getElementById('tw-nav-toggle');
        const overlay = document.getElementById('tw-overlay');
        const nav = document.getElementById('tw-mobile-nav');
        const closeBtn = document.getElementById('tw-nav-close');
        if (toggle && overlay && nav && closeBtn) {
          let lastFocused: Element | null = null;
          function openMenu() {
            lastFocused = document.activeElement;
            nav!.classList.add('open');
            overlay!.classList.add('open');
            toggle!.setAttribute('aria-expanded', 'true');
            document.body.style.overflow = 'hidden';
            closeBtn!.focus();
          }
          function closeMenu() {
            nav!.classList.remove('open');
            overlay!.classList.remove('open');
            toggle!.setAttribute('aria-expanded', 'false');
            document.body.style.overflow = '';
            (lastFocused as HTMLElement | null)?.focus();
          }
          toggle.addEventListener('click', openMenu);
          closeBtn.addEventListener('click', closeMenu);
          overlay.addEventListener('click', closeMenu);
          document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && nav!.classList.contains('open')) closeMenu();
          });
        }
      </script>
    </slot>

    <main>
      <slot />
    </main>

    <slot name="footer">
      <!-- Default footer — override with named slot if needed -->
      <footer class="bg-slate-50 w-full py-12 border-t border-slate-200">
        <div class="flex flex-col md:flex-row justify-between items-center max-w-7xl mx-auto px-8 gap-6">
          <div class="flex flex-col items-center md:items-start gap-2">
            <div class="text-xl font-bold text-primary font-headline">Tropic Wings Transfers</div>
            <p class="text-sm text-slate-500 font-body">© {new Date().getFullYear()} Tropic Wings Cairns Tours &amp; Charters. All rights reserved.</p>
          </div>
          <div class="flex flex-wrap justify-center gap-8 text-sm text-slate-500">
            <a class="hover:text-primary transition-colors" href="/privacy">Privacy Policy</a>
            <a class="hover:text-primary transition-colors" href="/terms">Terms of Service</a>
            <a class="hover:text-primary transition-colors" href="https://tropicwings.com.au">Tropic Wings Main Site</a>
            <a class="hover:text-primary transition-colors" href="/contact">Contact</a>
          </div>
        </div>
      </footer>
    </slot>

  </body>
</html>
