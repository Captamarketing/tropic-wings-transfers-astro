---
// BookingWidget — used on the homepage hero
// Submits to /transfers with query params
---

<div class="glass-panel p-8 rounded-xl shadow-2xl border border-white/20">
  <div class="flex items-center gap-6 mb-6 border-b border-outline-variant/15 pb-4">
    <button
      id="btn-return"
      class="flex items-center gap-2 text-primary font-bold border-b-2 border-primary pb-4 transition-all"
    >
      <span class="material-symbols-outlined text-sm">sync_alt</span>
      <span class="font-headline tracking-wide uppercase text-xs">Return</span>
    </button>
    <button
      id="btn-oneway"
      class="flex items-center gap-2 text-on-surface-variant font-medium pb-4 hover:text-primary transition-all"
    >
      <span class="material-symbols-outlined text-sm">trending_flat</span>
      <span class="font-headline tracking-wide uppercase text-xs">One Way</span>
    </button>
  </div>

  <form action="/transfers" method="get">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
      <div class="space-y-1">
        <label class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant ml-1 font-label">
          Travelling From
        </label>
        <div class="bg-surface-container-high rounded-lg p-4 flex items-center gap-3">
          <span class="material-symbols-outlined text-primary">flight_land</span>
          <select name="from" class="bg-transparent border-none focus:ring-0 text-sm font-medium w-full text-on-surface appearance-none">
            <option value="cairns-airport">Cairns Airport (CNS)</option>
            <option value="port-douglas">Port Douglas</option>
          </select>
        </div>
      </div>

      <div class="space-y-1">
        <label class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant ml-1 font-label">
          Travelling To
        </label>
        <div class="bg-surface-container-high rounded-lg p-4 flex items-center gap-3">
          <span class="material-symbols-outlined text-primary">near_me</span>
          <select name="to" class="bg-transparent border-none focus:ring-0 text-sm font-medium w-full text-on-surface appearance-none">
            <option value="port-douglas">Port Douglas</option>
            <option value="cairns-airport">Cairns Airport (CNS)</option>
          </select>
        </div>
      </div>

      <div class="space-y-1">
        <label class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant ml-1 font-label">
          Travel Date
        </label>
        <div class="bg-surface-container-high rounded-lg p-4 flex items-center gap-3">
          <span class="material-symbols-outlined text-primary">calendar_today</span>
          <input
            name="date"
            type="date"
            class="bg-transparent border-none focus:ring-0 text-sm font-medium w-full text-on-surface"
          />
        </div>
      </div>

      <div class="space-y-1">
        <label class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant ml-1 font-label">
          Passengers
        </label>
        <div class="bg-surface-container-high rounded-lg p-4 flex items-center gap-3">
          <span class="material-symbols-outlined text-primary">group</span>
          <select name="passengers" class="bg-transparent border-none focus:ring-0 text-sm font-medium w-full text-on-surface appearance-none">
            <option>1 Passenger</option>
            <option>2 Passengers</option>
            <option>3 Passengers</option>
            <option>4 Passengers</option>
            <option>5+ Passengers</option>
          </select>
        </div>
      </div>
    </div>

    <div class="mt-6 flex justify-end">
      <button
        type="submit"
        class="action-pill-gradient text-on-primary px-12 py-4 rounded-full font-headline font-bold text-lg flex items-center gap-3 shadow-xl shadow-primary/30 hover:scale-[1.02] transition-transform"
      >
        Find Transfers
        <span class="material-symbols-outlined">arrow_forward</span>
      </button>
    </div>
  </form>
</div>

<script>
  // Swap from/to when direction toggles
  const fromSelect = document.querySelector('select[name="from"]') as HTMLSelectElement;
  const toSelect = document.querySelector('select[name="to"]') as HTMLSelectElement;

  document.getElementById('btn-return')?.addEventListener('click', () => {
    document.getElementById('btn-return')?.classList.add('text-primary', 'font-bold', 'border-b-2', 'border-primary');
    document.getElementById('btn-oneway')?.classList.remove('text-primary', 'font-bold', 'border-b-2', 'border-primary');
  });

  document.getElementById('btn-oneway')?.addEventListener('click', () => {
    document.getElementById('btn-oneway')?.classList.add('text-primary', 'font-bold', 'border-b-2', 'border-primary');
    document.getElementById('btn-return')?.classList.remove('text-primary', 'font-bold', 'border-b-2', 'border-primary');
  });

  // Keep from/to in sync (prevent same value on both)
  fromSelect?.addEventListener('change', () => {
    if (fromSelect.value === toSelect.value) {
      toSelect.value = fromSelect.value === 'cairns-airport' ? 'port-douglas' : 'cairns-airport';
    }
  });
  toSelect?.addEventListener('change', () => {
    if (toSelect.value === fromSelect.value) {
      fromSelect.value = toSelect.value === 'cairns-airport' ? 'port-douglas' : 'cairns-airport';
    }
  });
</script>
