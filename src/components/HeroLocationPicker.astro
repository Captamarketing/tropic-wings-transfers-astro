---
import { RESPAX_ROUTES, BOOKING_URL } from '../constants/booking';

// Location definitions
const LOCATIONS = {
  cns: "Cairns Airport (CNS)",
  pd:  "Port Douglas",
  pc:  "Palm Cove",
  cn:  "Cairns City / Hotels",
};

// Which drop-off options are valid for each pick-up
const DROP_OPTS: Record<string, string[]> = {
  cns: ["pd", "pc", "cn"],
  pd:  ["cns"],
  pc:  ["cns"],
  cn:  ["cns"],
};
---

<div class="w-full max-w-2xl mx-auto">
  <div class="bg-white rounded-2xl shadow-2xl flex flex-col sm:flex-row items-stretch sm:items-center overflow-hidden">

    <!-- Pick-up -->
    <div class="flex-1 px-5 py-4 sm:py-3 flex items-center gap-3 border-b sm:border-b-0 sm:border-r border-gray-100">
      <span class="material-symbols-outlined text-primary text-xl shrink-0" style="font-variation-settings:'FILL' 1;" aria-hidden="true">flight_land</span>
      <div class="flex flex-col min-w-0 w-full">
        <label for="lp-from" class="text-[9px] font-black uppercase tracking-[0.18em] text-gray-400 font-label leading-none mb-1">Pick-up</label>
        <select
          id="lp-from"
          class="bg-transparent border-none p-0 focus:ring-0 text-sm font-bold text-on-surface font-headline appearance-none w-full cursor-pointer"
        >
          {Object.entries(LOCATIONS).map(([val, label]) => (
            <option value={val}>{label}</option>
          ))}
        </select>
      </div>
    </div>

    <!-- Swap button -->
    <button
      id="lp-swap"
      type="button"
      aria-label="Swap pick-up and drop-off"
      class="hidden sm:flex self-center shrink-0 w-9 h-9 rounded-full border-2 border-gray-200 items-center justify-center hover:border-primary hover:text-primary text-gray-400 transition-all mx-1"
    >
      <span class="material-symbols-outlined text-base" aria-hidden="true">swap_horiz</span>
    </button>

    <!-- Drop-off -->
    <div class="flex-1 px-5 py-4 sm:py-3 flex items-center gap-3 border-b sm:border-b-0 border-gray-100">
      <span class="material-symbols-outlined text-primary text-xl shrink-0" style="font-variation-settings:'FILL' 1;" aria-hidden="true">location_on</span>
      <div class="flex flex-col min-w-0 w-full">
        <label for="lp-to" class="text-[9px] font-black uppercase tracking-[0.18em] text-gray-400 font-label leading-none mb-1">Drop-off</label>
        <select
          id="lp-to"
          class="bg-transparent border-none p-0 focus:ring-0 text-sm font-bold text-on-surface font-headline appearance-none w-full cursor-pointer"
        >
          <!-- Populated by JS based on pick-up selection -->
        </select>
      </div>
    </div>

    <!-- Find transfers CTA -->
    <a
      id="lp-cta"
      href={BOOKING_URL}
      class="action-pill-gradient text-white font-headline font-bold text-sm px-6 py-5 sm:py-0 sm:self-stretch flex items-center justify-center gap-2 whitespace-nowrap hover:opacity-90 transition-opacity sm:rounded-r-2xl sm:rounded-l-none rounded-b-2xl sm:rounded-b-none"
    >
      Find transfers
      <span class="material-symbols-outlined text-base" aria-hidden="true">arrow_forward</span>
    </a>

  </div>
</div>

<script define:vars={{ RESPAX_ROUTES, DROP_OPTS, LOCATIONS }}>
  const fromSel = /** @type {HTMLSelectElement} */ (document.getElementById('lp-from'));
  const toSel   = /** @type {HTMLSelectElement} */ (document.getElementById('lp-to'));
  const cta     = /** @type {HTMLAnchorElement} */ (document.getElementById('lp-cta'));
  const swapBtn = document.getElementById('lp-swap');

  /** Rebuild the drop-off options based on current pick-up value */
  function refreshToOptions(preserveValue) {
    const from = fromSel.value;
    const validTo = DROP_OPTS[from] || [];
    toSel.innerHTML = '';
    validTo.forEach((val) => {
      const opt = document.createElement('option');
      opt.value = val;
      opt.textContent = LOCATIONS[val];
      toSel.appendChild(opt);
    });
    // Restore previous value if still valid
    if (preserveValue && validTo.includes(preserveValue)) {
      toSel.value = preserveValue;
    }
    updateCta();
  }

  function updateCta() {
    const key = `${fromSel.value}-${toSel.value}`;
    cta.href = RESPAX_ROUTES[key] || '#';
  }

  fromSel.addEventListener('change', () => refreshToOptions(null));
  toSel.addEventListener('change', updateCta);

  swapBtn?.addEventListener('click', () => {
    const prevFrom = fromSel.value;
    const prevTo   = toSel.value;
    // Only swap if the reverse route is valid
    const reverseKey = `${prevTo}-${prevFrom}`;
    if (RESPAX_ROUTES[reverseKey]) {
      fromSel.value = prevTo;
      refreshToOptions(prevFrom);
    }
  });

  // Initialise drop-off options on load
  refreshToOptions(null);
</script>
