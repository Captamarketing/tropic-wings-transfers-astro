---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Complete Your Booking | Tropic Wings Transfers"
  description="Complete your Cairns Airport to Port Douglas transfer booking with Tropic Wings. Enter passenger details, review your booking summary and confirm."
  canonical="/booking"
  noindex={true}
>

  <!-- PROGRESS BAR -->
  <div slot="nav" class="bg-surface-container-lowest border-b border-outline-variant/30 py-5 px-8">
    <div class="max-w-5xl mx-auto flex items-center justify-between">
      <a href="/" class="font-headline font-black text-primary text-lg">Tropic Wings Transfers</a>
      <div class="flex items-center gap-2 font-label text-sm">
        <div class="flex items-center gap-2 text-on-surface-variant">
          <div class="w-7 h-7 rounded-full bg-surface-container-high flex items-center justify-center text-xs font-black">
            <span class="material-symbols-outlined text-sm" style="font-variation-settings:'FILL' 1;">check_circle</span>
          </div>
          <span class="hidden md:block">Selection</span>
        </div>
        <div class="w-10 h-[2px] bg-outline-variant"></div>
        <div class="flex items-center gap-2 text-primary font-bold">
          <div class="w-7 h-7 rounded-full bg-primary text-on-primary flex items-center justify-center text-xs font-black">2</div>
          <span class="hidden md:block">Passengers</span>
        </div>
        <div class="w-10 h-[2px] bg-outline-variant"></div>
        <div class="flex items-center gap-2 text-on-surface-variant">
          <div class="w-7 h-7 rounded-full bg-surface-container-high flex items-center justify-center text-xs font-black">3</div>
          <span class="hidden md:block">Payment</span>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-5xl mx-auto px-8 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

      <!-- FORM -->
      <div class="lg:col-span-2 space-y-8">

        <!-- Lead Passenger -->
        <div class="bg-surface-container-lowest rounded-xl p-8 shadow-sm">
          <div class="flex items-center gap-3 mb-6">
            <span class="material-symbols-outlined text-primary text-2xl">person</span>
            <div>
              <h2 class="font-headline font-bold text-xl">Lead Passenger Details</h2>
              <p class="text-on-surface-variant text-xs font-body">Booking confirmation will be sent to this contact.</p>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-4 mb-4">
            <div>
              <label class="block text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mb-2 font-label">First Name</label>
              <input type="text" placeholder="Jane" class="w-full bg-surface-container-high rounded-lg px-4 py-3 text-sm font-medium border-none focus:ring-2 focus:ring-primary focus:bg-surface-container-highest outline-none" />
            </div>
            <div>
              <label class="block text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mb-2 font-label">Last Name</label>
              <input type="text" placeholder="Smith" class="w-full bg-surface-container-high rounded-lg px-4 py-3 text-sm font-medium border-none focus:ring-2 focus:ring-primary focus:bg-surface-container-highest outline-none" />
            </div>
          </div>
          <div class="mb-4">
            <label class="block text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mb-2 font-label">Email Address</label>
            <input type="email" placeholder="jane.smith@example.com" class="w-full bg-surface-container-high rounded-lg px-4 py-3 text-sm font-medium border-none focus:ring-2 focus:ring-primary outline-none" />
          </div>
          <div class="grid grid-cols-2 gap-4 mb-4">
            <div>
              <label class="block text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mb-2 font-label">Phone Number</label>
              <div class="flex gap-2">
                <select class="bg-surface-container-high rounded-lg px-3 py-3 text-sm font-medium border-none w-24 appearance-none outline-none">
                  <option>+61</option>
                  <option>+1</option>
                  <option>+44</option>
                </select>
                <input type="tel" placeholder="04XX XXX XXX" class="flex-1 bg-surface-container-high rounded-lg px-4 py-3 text-sm font-medium border-none outline-none" />
              </div>
            </div>
            <div>
              <label class="block text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mb-2 font-label">Nationality</label>
              <select class="w-full bg-surface-container-high rounded-lg px-4 py-3 text-sm font-medium border-none appearance-none outline-none">
                <option>Australia</option>
                <option>United Kingdom</option>
                <option>United States</option>
                <option>Germany</option>
                <option>Other</option>
              </select>
            </div>
          </div>
          <div>
            <label class="block text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mb-2 font-label">
              Flight Number <span class="text-outline normal-case tracking-normal font-medium">(optional — helps us monitor delays)</span>
            </label>
            <input type="text" placeholder="e.g. QF 906" class="w-full bg-surface-container-high rounded-lg px-4 py-3 text-sm font-medium border-none outline-none" />
          </div>
        </div>

        <!-- Additional Passengers -->
        <div class="bg-surface-container-lowest rounded-xl p-8 shadow-sm">
          <div class="flex items-center justify-between mb-6">
            <div class="flex items-center gap-3">
              <span class="material-symbols-outlined text-primary text-2xl">group_add</span>
              <h2 class="font-headline font-bold text-xl">Additional Passengers</h2>
            </div>
            <span class="bg-secondary-fixed text-on-secondary-fixed text-xs font-black px-3 py-1 rounded-full font-label">1 Remaining</span>
          </div>
          <div class="border-l-4 border-primary/30 pl-6">
            <p class="font-label text-xs uppercase tracking-widest text-on-surface-variant mb-4">Passenger 2</p>
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mb-2 font-label">First Name</label>
                <input type="text" placeholder="John" class="w-full bg-surface-container-high rounded-lg px-4 py-3 text-sm font-medium border-none outline-none" />
              </div>
              <div>
                <label class="block text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mb-2 font-label">Last Name</label>
                <input type="text" placeholder="Smith" class="w-full bg-surface-container-high rounded-lg px-4 py-3 text-sm font-medium border-none outline-none" />
              </div>
            </div>
          </div>
        </div>

        <!-- Special Requests -->
        <div class="bg-surface-container-lowest rounded-xl p-8 shadow-sm">
          <div class="flex items-center gap-3 mb-6">
            <span class="material-symbols-outlined text-primary text-2xl">edit_note</span>
            <h2 class="font-headline font-bold text-xl">Special Requests</h2>
          </div>
          <textarea
            class="w-full bg-surface-container-high rounded-lg px-4 py-3 text-sm font-medium border-none resize-none outline-none focus:ring-2 focus:ring-primary"
            rows="4"
            placeholder="e.g. Child seat required, travelling with a surfboard, specific drop-off location within Port Douglas, wheelchair accessibility needs…"
          ></textarea>
          <p class="text-xs text-on-surface-variant font-body mt-2">For large items or special requirements, we recommend calling us to confirm availability.</p>
        </div>

      </div>

      <!-- BOOKING SUMMARY -->
      <aside class="lg:col-span-1">
        <div class="bg-surface-container-lowest rounded-xl p-8 shadow-sm sticky top-6">
          <h3 class="font-headline font-bold text-lg mb-6">Booking Summary</h3>
          <div class="relative pl-6 mb-8">
            <div class="absolute left-0 top-1 bottom-1 w-[2px] bg-gradient-to-b from-primary to-primary-container"></div>
            <div class="absolute left-[-3px] top-1 w-2 h-2 rounded-full bg-primary"></div>
            <div class="absolute left-[-3px] bottom-1 w-2 h-2 rounded-full border-2 border-primary bg-white"></div>
            <div class="mb-6">
              <p class="text-xs font-label uppercase tracking-widest text-on-surface-variant mb-1">From</p>
              <p class="font-headline font-bold text-sm">Cairns Airport (CNS)</p>
            </div>
            <div>
              <p class="text-xs font-label uppercase tracking-widest text-on-surface-variant mb-1">To</p>
              <p class="font-headline font-bold text-sm">Port Douglas</p>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-4 mb-6 text-sm">
            <div>
              <p class="text-xs font-label uppercase tracking-widest text-on-surface-variant mb-1">Service</p>
              <p class="font-body font-semibold">Seat in Coach</p>
            </div>
            <div>
              <p class="text-xs font-label uppercase tracking-widest text-on-surface-variant mb-1">Passengers</p>
              <p class="font-body font-semibold">2 Adults</p>
            </div>
          </div>
          <div class="border-t border-outline-variant/30 pt-6 mb-6 space-y-3">
            <div class="flex justify-between text-sm font-body">
              <span class="text-on-surface-variant">Transfer fare (×2)</span>
              <span class="font-semibold">$XX.00</span>
            </div>
            <div class="flex justify-between text-sm font-body">
              <span class="text-on-surface-variant">Service fee</span>
              <span class="font-semibold">$X.00</span>
            </div>
            <div class="flex justify-between font-headline font-bold text-lg pt-3 border-t border-outline-variant/30">
              <span>Total (AUD)</span>
              <span class="text-primary">$XX.00</span>
            </div>
            <p class="text-xs text-on-surface-variant font-body">All taxes included</p>
          </div>
          <button class="w-full action-pill-gradient text-on-primary py-4 rounded-full font-headline font-bold flex items-center justify-center gap-2 shadow-lg hover:scale-[1.02] transition-transform">
            Continue to Payment
            <span class="material-symbols-outlined">arrow_forward</span>
          </button>
          <div class="mt-6 flex items-center justify-center gap-4 text-on-surface-variant">
            <span class="material-symbols-outlined text-xl">lock</span>
            <span class="material-symbols-outlined text-xl">verified_user</span>
            <span class="material-symbols-outlined text-xl">credit_card</span>
          </div>
          <p class="text-center text-xs text-on-surface-variant font-body mt-2">Secure payment — your data is protected</p>
          <div class="mt-6 bg-secondary-fixed/20 border border-secondary-fixed rounded-xl p-4 flex items-center gap-3">
            <span class="material-symbols-outlined text-on-secondary-container text-xl" style="font-variation-settings:'FILL' 1;">sell</span>
            <div>
              <p class="font-headline font-bold text-xs text-on-secondary-container">Free Cancellation</p>
              <p class="text-on-secondary-container/70 text-xs font-body">Cancel up to 24h before for a full refund</p>
            </div>
          </div>
        </div>
      </aside>

    </div>
  </div>

</BaseLayout>
