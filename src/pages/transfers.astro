---
import BaseLayout from '../layouts/BaseLayout.astro';
import TransferCard from '../components/TransferCard.astro';

const departures = [
  { departTime: "07:30", arriveTime: "08:45", departStop: "Cairns Airport", arriveStop: "Port Douglas", duration: "1h 15m", stops: "Non-stop", price: "$XX", badge: "First Departure", badgeStyle: "lime" as const },
  { departTime: "09:30", arriveTime: "11:00", departStop: "Cairns Airport", arriveStop: "Port Douglas", duration: "1h 30m", stops: "1 Stop (Palm Cove)", price: "$XX" },
  { departTime: "11:00", arriveTime: "12:15", departStop: "Cairns Airport", arriveStop: "Port Douglas", duration: "1h 15m", stops: "Non-stop", price: "$XX" },
  { departTime: "13:00", arriveTime: "14:15", departStop: "Cairns Airport", arriveStop: "Port Douglas", duration: "1h 15m", stops: "Non-stop", price: "$XX", badge: "Popular", badgeStyle: "primary" as const },
  { departTime: "15:00", arriveTime: "16:15", departStop: "Cairns Airport", arriveStop: "Port Douglas", duration: "1h 15m", stops: "Non-stop", price: "$XX" },
  { departTime: "16:30", arriveTime: "18:00", departStop: "Cairns Airport", arriveStop: "Port Douglas", duration: "1h 30m", stops: "1 Stop (Palm Cove)", price: "$XX" },
  { departTime: "18:00", arriveTime: "19:15", departStop: "Cairns Airport", arriveStop: "Port Douglas", duration: "1h 15m", stops: "Non-stop", price: "$XX" },
];
---

<BaseLayout
  title="Cairns to Port Douglas — Available Transfers | Tropic Wings"
  description="Browse available Seat in Coach and Private Transfer departures between Cairns Airport and Port Douglas. Multiple daily departures. Book online instantly."
  canonical="/transfers"
>

  <!-- EDITORIAL HERO -->
  <section class="relative h-[420px] overflow-hidden bg-surface-container-low hero-clip">
    <div class="absolute inset-0">
      <img
        class="w-full h-full object-cover opacity-90 scale-105 transform translate-y-[-10%]"
        src="https://upload.wikimedia.org/wikipedia/commons/thumb/2/2a/Captain_Cook_Highway_-_Port_Douglas.jpg/1280px-Captain_Cook_Highway_-_Port_Douglas.jpg"
        alt="Captain Cook Highway coastal road between Cairns and Port Douglas, Far North Queensland"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-primary/50 to-transparent"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-8 h-full flex flex-col justify-center">
      <div class="max-w-2xl bg-white/10 backdrop-blur-md p-8 rounded-xl border border-white/20">
        <span class="inline-block px-3 py-1 mb-4 text-xs font-bold tracking-[0.2em] text-secondary-container bg-primary/20 rounded uppercase font-label">Direct Route</span>
        <h1 class="text-5xl md:text-7xl font-headline font-extrabold text-white leading-tight tracking-tighter">
          Cairns <span class="text-secondary-fixed">to</span><br/>Port Douglas
        </h1>
        <div class="flex flex-wrap items-center gap-6 mt-6 text-white font-medium text-sm">
          <div class="flex items-center gap-2">
            <span class="material-symbols-outlined text-secondary-fixed text-base">calendar_month</span>
            <span>Select a date to see live availability</span>
          </div>
          <a href="/" class="flex items-center gap-1 border-l border-white/30 pl-6 text-white/70 hover:text-secondary-fixed transition-colors text-xs font-label">
            <span class="material-symbols-outlined text-sm">edit</span> Change search
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTENT GRID -->
  <div class="max-w-7xl mx-auto px-8 grid grid-cols-12 gap-10 -mt-16 relative z-10 pb-24">

    <!-- SIDEBAR -->
    <aside class="col-span-12 lg:col-span-3 space-y-6 pt-4">
      <div class="bg-surface-container-lowest p-8 rounded-xl shadow-sm space-y-10">
        <div>
          <h2 class="text-lg font-headline font-bold mb-6 text-primary">Refine Journey</h2>

          <div class="space-y-4 mb-8">
            <p class="text-xs font-bold uppercase tracking-widest text-on-surface-variant font-label">Time of Day</p>
            <div class="grid grid-cols-1 gap-2">
              <label class="flex items-center gap-3 p-3 rounded-lg bg-secondary-fixed/20 border-2 border-secondary cursor-pointer">
                <input checked type="checkbox" class="w-5 h-5 rounded border-secondary text-secondary focus:ring-secondary"/>
                <span class="text-sm font-bold text-on-secondary-container">Morning (06:00–12:00)</span>
              </label>
              <label class="flex items-center gap-3 p-3 rounded-lg hover:bg-surface-container cursor-pointer">
                <input type="checkbox" class="w-5 h-5 rounded border-outline-variant text-primary focus:ring-primary"/>
                <span class="text-sm font-medium">Afternoon (12:00–18:00)</span>
              </label>
              <label class="flex items-center gap-3 p-3 rounded-lg hover:bg-surface-container cursor-pointer">
                <input type="checkbox" class="w-5 h-5 rounded border-outline-variant text-primary focus:ring-primary"/>
                <span class="text-sm font-medium">Evening (18:00+)</span>
              </label>
            </div>
          </div>

          <div class="mb-8">
            <p class="text-xs font-bold uppercase tracking-widest text-on-surface-variant font-label mb-4">Service Type</p>
            <div class="space-y-2">
              <label class="flex justify-between items-center p-3 rounded-lg hover:bg-surface-container cursor-pointer">
                <div class="flex items-center gap-3">
                  <span class="material-symbols-outlined text-outline text-sm">directions_bus</span>
                  <span class="text-sm font-medium">Seat in Coach</span>
                </div>
                <input checked type="checkbox" class="w-5 h-5 rounded border-primary text-primary"/>
              </label>
              <label class="flex justify-between items-center p-3 rounded-lg hover:bg-surface-container cursor-pointer">
                <div class="flex items-center gap-3">
                  <span class="material-symbols-outlined text-outline text-sm">electric_car</span>
                  <span class="text-sm font-medium">Private Transfer</span>
                </div>
                <input type="checkbox" class="w-5 h-5 rounded border-outline-variant text-primary"/>
              </label>
            </div>
          </div>

          <button class="w-full py-3 bg-surface-container-high text-on-surface-variant font-bold rounded-full hover:bg-surface-container-highest transition-all text-sm font-label">
            Clear All Filters
          </button>
        </div>
      </div>

      <!-- Private upsell -->
      <a href="/private-transfer" class="block bg-primary-container p-8 rounded-xl relative overflow-hidden group cursor-pointer">
        <div class="relative z-10">
          <span class="text-xs font-black font-label uppercase tracking-widest text-on-primary-container/70 mb-2 block">Premium Option</span>
          <h3 class="text-xl font-headline font-bold text-on-primary-container leading-tight mb-2">Upgrade to Private Transfer</h3>
          <p class="text-sm text-on-primary-container/80 mb-6 font-body">Just your group in a fully electric VW ID Buzz. No stops, no strangers.</p>
          <span class="text-sm font-bold text-on-primary-container flex items-center gap-2 group-hover:gap-4 transition-all font-headline">
            Learn more <span class="material-symbols-outlined">arrow_forward</span>
          </span>
        </div>
        <div class="absolute -right-4 -bottom-4 opacity-10 transform group-hover:scale-110 transition-transform duration-500">
          <span class="material-symbols-outlined text-[120px]">electric_car</span>
        </div>
      </a>
    </aside>

    <!-- RESULTS -->
    <section class="col-span-12 lg:col-span-9 space-y-6">
      <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 p-5 bg-surface-container-low rounded-xl mt-4">
        <p class="text-on-surface-variant text-sm font-body">
          <span class="font-bold text-primary">{departures.length} departures</span> available — Cairns Airport → Port Douglas
        </p>
        <div class="flex items-center gap-4">
          <span class="text-xs font-bold text-outline uppercase tracking-wider font-label">Sort by:</span>
          <select class="bg-transparent border-none text-sm font-bold text-primary focus:ring-0 cursor-pointer font-headline">
            <option>Departure (Earliest)</option>
            <option>Price (Lowest)</option>
          </select>
        </div>
      </div>

      <div class="space-y-5">
        {departures.map((d) => (
          <TransferCard {...d} />
        ))}
      </div>

      <div class="flex justify-center pt-4">
        <button class="flex items-center gap-3 px-12 py-4 bg-surface-container-high border-2 border-primary/10 text-primary font-extrabold rounded-full hover:bg-primary hover:text-on-primary transition-all duration-300 font-headline">
          Show More Departures
          <span class="material-symbols-outlined">expand_more</span>
        </button>
      </div>
    </section>

  </div>
</BaseLayout>
