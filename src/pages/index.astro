---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookingWidget from '../components/BookingWidget.astro';

const schema = [
  {
    "@type": "WebSite",
    "@id": "https://transfers.tropicwings.com.au/#website",
    "url": "https://transfers.tropicwings.com.au",
    "name": "Tropic Wings Transfers",
    "description": "Direct scheduled coach transfers and private exclusive transfers between Cairns Airport and Port Douglas.",
    "publisher": { "@id": "https://transfers.tropicwings.com.au/#organization" },
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://transfers.tropicwings.com.au/transfers?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  },
  {
    "@type": "TransportationCompany",
    "@id": "https://transfers.tropicwings.com.au/#organization",
    "name": "Tropic Wings Transfers",
    "alternateName": ["Tropic Wings Cairns Tours & Charters", "Tropic Wings"],
    "url": "https://transfers.tropicwings.com.au",
    "telephone": "+61740419400",
    "email": "info@tropicwings.com.au",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "278 Hartley Street",
      "addressLocality": "Cairns",
      "addressRegion": "QLD",
      "postalCode": "4870",
      "addressCountry": "AU"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": -16.9186,
      "longitude": 145.7781
    },
    "areaServed": [
      { "@type": "City", "name": "Cairns", "sameAs": "https://www.wikidata.org/wiki/Q170360" },
      { "@type": "City", "name": "Port Douglas", "sameAs": "https://www.wikidata.org/wiki/Q1426847" },
      { "@type": "Place", "name": "Palm Cove, Queensland" },
      { "@type": "Place", "name": "Cairns Airport (CNS)" }
    ],
    "foundingDate": "1981",
    "description": "Tropic Wings has operated tours and transfers in tropical North Queensland since 1981. Ecocertified for over 20 years and inducted into the Ecotourism Australia Hall of Fame.",
    "sameAs": ["https://tropicwings.com.au", "https://www.facebook.com/CairnsTours"]
  },
  {
    "@type": "Service",
    "@id": "https://transfers.tropicwings.com.au/#seat-in-coach",
    "name": "Seat in Coach — Cairns Airport to Port Douglas",
    "description": "Scheduled shared coach transfer between Cairns Airport (CNS) and Port Douglas, Queensland. Multiple daily departures, airport meet and greet, air-conditioned modern coaches.",
    "provider": { "@id": "https://transfers.tropicwings.com.au/#organization" },
    "serviceType": "Airport Shuttle Transfer",
    "offers": { "@type": "Offer", "priceCurrency": "AUD", "availability": "https://schema.org/InStock", "url": "https://transfers.tropicwings.com.au/transfers" }
  },
  {
    "@type": "Service",
    "@id": "https://transfers.tropicwings.com.au/#private-transfer",
    "name": "Private Exclusive Transfer — Cairns Airport to Port Douglas",
    "description": "Private door-to-door transfer between Cairns Airport and Port Douglas in a fully electric VW ID Buzz. Exclusive to your group, no other passengers.",
    "provider": { "@id": "https://transfers.tropicwings.com.au/#organization" },
    "serviceType": "Private Airport Transfer",
    "offers": { "@type": "Offer", "priceCurrency": "AUD", "availability": "https://schema.org/InStock", "url": "https://transfers.tropicwings.com.au/private-transfer" }
  },
  {
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How do I get from Cairns Airport to Port Douglas?",
        "acceptedAnswer": { "@type": "Answer", "text": "The most convenient way to travel from Cairns Airport (CNS) to Port Douglas is by transfer with Tropic Wings. We offer Seat in Coach (shared scheduled transfers with multiple daily departures) and Private Exclusive Transfers in a fully electric VW ID Buzz. The journey takes approximately 70–75 minutes via the Captain Cook Highway." }
      },
      {
        "@type": "Question",
        "name": "How far is Cairns Airport from Port Douglas?",
        "acceptedAnswer": { "@type": "Answer", "text": "Cairns Airport is approximately 70km from Port Douglas via the Captain Cook Highway. The journey takes approximately 70–75 minutes by direct transfer." }
      },
      {
        "@type": "Question",
        "name": "How much does a transfer from Cairns to Port Douglas cost?",
        "acceptedAnswer": { "@type": "Answer", "text": "Tropic Wings offers Seat in Coach transfers at competitive per-person fares. Private Exclusive Transfers are priced per vehicle. Children 2–11 travel at a reduced rate; infants under 2 travel free. Visit our booking page for current pricing." }
      },
      {
        "@type": "Question",
        "name": "Do you meet passengers at Cairns Airport arrivals?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. Your Tropic Wings driver will meet you in the arrivals/baggage collection area at Cairns Airport (CNS) holding a Tropic Wings Transfers sign." }
      }
    ]
  }
];
---

<BaseLayout
  title="Cairns Airport to Port Douglas Transfers | Tropic Wings"
  description="Direct scheduled coach transfers and private exclusive transfers between Cairns Airport and Port Douglas. Operated by Tropic Wings — est. 1981, Ecocertified 20+ years."
  canonical="/"
  schema={schema}
>

  <!-- HERO -->
  <header class="relative w-full h-[900px] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img
        class="w-full h-full object-cover"
        src="https://tropicwings.com.au/wp-content/uploads/2022/11/Lg_160419__1589-scaled.jpg"
        alt="Cairns Airport to Port Douglas transfer — Tropic Wings"
      />
      <div class="absolute inset-0 bg-gradient-to-br from-black/50 via-black/20 to-transparent"></div>
    </div>
    <div class="relative z-10 w-full max-w-5xl px-6">
      <div class="mb-8 text-center">
        <span class="inline-block bg-secondary-fixed text-on-secondary-fixed text-xs font-black px-4 py-1.5 rounded-full uppercase tracking-widest font-label mb-4">Daily Departures</span>
        <h1 class="text-5xl md:text-7xl font-headline font-extrabold text-white leading-tight tracking-tighter drop-shadow-lg">
          Cairns Airport<br/>to Port Douglas.
        </h1>
        <p class="text-white/80 mt-4 text-lg font-body max-w-xl mx-auto">Reliable, comfortable, direct. The trusted transfer operated by Tropic Wings since 1981.</p>
      </div>
      <BookingWidget />
    </div>
  </header>

  <!-- TRUST BAR -->
  <div class="bg-primary text-on-primary py-5 px-8">
    <div class="max-w-7xl mx-auto flex flex-wrap justify-center gap-x-12 gap-y-3 font-label text-sm font-semibold tracking-wide">
      <span class="flex items-center gap-2"><span class="material-symbols-outlined text-secondary-fixed text-base">eco</span>Ecocertified 20+ Years</span>
      <span class="flex items-center gap-2"><span class="material-symbols-outlined text-secondary-fixed text-base">flight</span>Direct Cairns Airport Service</span>
      <span class="flex items-center gap-2"><span class="material-symbols-outlined text-secondary-fixed text-base">history</span>Est. 1981 — Cairns' Most Trusted</span>
      <span class="flex items-center gap-2"><span class="material-symbols-outlined text-secondary-fixed text-base">electric_bolt</span>Australia's First Electric Tour Fleet</span>
      <span class="flex items-center gap-2"><span class="material-symbols-outlined text-secondary-fixed text-base">schedule</span>Multiple Daily Departures</span>
    </div>
  </div>

  <!-- SERVICES BENTO -->
  <section class="max-w-7xl mx-auto px-8 py-24">
    <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
      <div class="max-w-2xl">
        <span class="text-primary font-headline font-extrabold uppercase tracking-widest text-sm mb-4 block">Cairns ↔ Port Douglas</span>
        <h2 class="text-5xl md:text-6xl font-headline font-black tracking-tighter text-on-surface leading-tight">Professional services, modern, clean and tidy fleet.</h2>
      </div>
      <p class="text-on-surface-variant max-w-sm font-body text-lg">Direct, daily transfers along one of Australia's most spectacular coastal drives — choose the experience that suits you.</p>
    </div>

    <div class="grid grid-cols-12 gap-6 auto-rows-[320px]">
      <!-- Coach — large -->
      <a href="/seat-in-coach" class="col-span-12 md:col-span-8 relative group overflow-hidden rounded-xl bg-surface-container-low cursor-pointer">
        <img class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
          src="https://tropicwings.com.au/wp-content/uploads/2024/09/6.jpg"
          alt="Modern air-conditioned coach for Seat in Coach transfers between Cairns Airport and Port Douglas"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent"></div>
        <div class="absolute bottom-8 left-8 right-8 text-white">
          <span class="bg-secondary-fixed text-on-secondary-fixed px-3 py-1 rounded-full text-xs font-black font-label uppercase tracking-wider mb-3 inline-block">Most Popular</span>
          <h3 class="text-4xl font-headline font-bold mb-2">Seat in Coach</h3>
          <p class="text-white/80 text-sm font-body mb-4 max-w-md">Comfortable scheduled transfers with multiple daily departures. Book your seat, we handle the rest.</p>
          <span class="flex items-center gap-2 text-secondary-fixed font-bold font-headline text-sm">View Timetables &amp; Book <span class="material-symbols-outlined text-base">arrow_forward</span></span>
        </div>
      </a>

      <!-- Private — small -->
      <a href="/private-transfer" class="col-span-12 md:col-span-4 relative group overflow-hidden rounded-xl bg-surface-container-low cursor-pointer">
        <img class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
          src="https://tropicwings.com.au/wp-content/uploads/2025/08/9.Fully-Electric-ID-Buzz-Private-Exclusive-Tours-by-Tropic-Wings-1.jpg"
          alt="VW ID Buzz electric vehicle for private Cairns Airport to Port Douglas transfers"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
        <div class="absolute bottom-8 left-8 right-8 text-white">
          <h3 class="text-2xl font-headline font-bold mb-2">Private Transfer</h3>
          <p class="text-white/70 text-sm font-body mb-3">Just your group. Fully electric VW ID Buzz. Zero stops.</p>
          <span class="flex items-center gap-2 text-secondary-fixed font-bold font-headline text-sm">View Pricing <span class="material-symbols-outlined text-base">arrow_forward</span></span>
        </div>
      </a>

      <!-- Route info -->
      <div class="col-span-12 md:col-span-4 relative group overflow-hidden rounded-xl bg-surface-container-low">
        <img class="absolute inset-0 w-full h-full object-cover opacity-60 transition-transform duration-700 group-hover:scale-110"
          src="https://tropicwings.com.au/wp-content/uploads/2022/08/Tropic-Wings-Mossman-Port-Douglas.jpg"
<<<<<<< HEAD
          alt="Four Mile Beach Port Douglas Queensland"
=======
          alt="Mossman Gorge and Port Douglas region, Far North Queensland"
>>>>>>> origin/main
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent"></div>
        <div class="absolute bottom-8 left-8 right-8 text-white">
          <h3 class="text-2xl font-headline font-bold mb-2">Port Douglas</h3>
          <div class="flex gap-4 text-sm font-label text-white/80">
            <span class="flex items-center gap-1"><span class="material-symbols-outlined text-sm text-secondary-fixed">straighten</span>~70km from Cairns</span>
            <span class="flex items-center gap-1"><span class="material-symbols-outlined text-sm text-secondary-fixed">schedule</span>~75 min</span>
          </div>
        </div>
      </div>

      <!-- Eco credentials -->
      <div class="col-span-12 md:col-span-8 relative group overflow-hidden rounded-xl bg-primary">
        <div class="absolute inset-0 opacity-10">
          <div class="absolute -right-20 -top-20 w-96 h-96 rounded-full bg-secondary-fixed"></div>
          <div class="absolute -left-10 -bottom-10 w-64 h-64 rounded-full bg-white"></div>
        </div>
        <div class="relative px-10 pt-10 pb-14 h-full flex flex-col justify-between">
          <div>
            <span class="material-symbols-outlined text-secondary-fixed text-5xl mb-4 block" style="font-variation-settings:'FILL' 1;">eco</span>
            <h3 class="text-3xl font-headline font-bold text-white mb-3">Australia's First Electric Tour Fleet</h3>
            <p class="text-white/75 font-body text-base max-w-xl">Tropic Wings has been Ecocertified for over 20 years and inducted into the Ecotourism Australia Hall of Fame. Our transfer fleet carries that same commitment — getting you to Port Douglas without costing the environment we all love.</p>
          </div>
          <div class="flex gap-6 mt-6">
            <div class="text-center">
              <p class="text-3xl font-headline font-black text-secondary-fixed">20+</p>
              <p class="text-white/70 text-xs font-label uppercase tracking-wider">Years Ecocertified</p>
            </div>
            <div class="text-center">
              <p class="text-3xl font-headline font-black text-secondary-fixed">1981</p>
              <p class="text-white/70 text-xs font-label uppercase tracking-wider">Founded</p>
            </div>
            <div class="text-center">
              <p class="text-3xl font-headline font-black text-secondary-fixed">7</p>
              <p class="text-white/70 text-xs font-label uppercase tracking-wider">Days a Week</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURES EDITORIAL -->
  <section class="bg-surface-container-low py-24 overflow-hidden">
    <div class="max-w-7xl mx-auto px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-20 items-center">
        <div class="relative">
          <div class="absolute -top-12 -left-12 w-64 h-64 bg-secondary/10 rounded-full blur-3xl"></div>
          <img
            class="relative z-10 rounded-xl shadow-2xl w-full object-cover h-96"
            src="https://tropicwings.com.au/wp-content/uploads/2026/04/Tropic-Wings-bus-Interior-scaled.png"
            alt="Interior of a modern Tropic Wings air-conditioned coach"
          />
          <div class="absolute -bottom-6 -right-6 z-20 bg-white p-6 rounded-xl shadow-lg max-w-[220px]">
            <div class="text-primary mb-3">
              <span class="material-symbols-outlined text-4xl" style="font-variation-settings:'FILL' 1;">eco</span>
            </div>
            <h4 class="font-headline font-bold text-base mb-1 text-on-surface">Sustainable Fleet</h4>
            <p class="text-on-surface-variant text-xs font-body leading-relaxed">Ecocertified since 2004 — protecting the tropics we love.</p>
          </div>
        </div>
        <div>
          <span class="text-primary font-headline font-extrabold uppercase tracking-widest text-sm mb-4 block">The Tropic Wings Standard</span>
          <h2 class="text-4xl md:text-5xl font-headline font-black tracking-tighter text-on-surface mb-12">Airport and FNQ transfers you can trust.</h2>
          <div class="space-y-10">
            <div class="flex gap-6">
              <div class="w-14 h-14 rounded-full bg-secondary-container flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-on-secondary-container">flight_land</span>
              </div>
              <div>
                <h3 class="text-lg font-headline font-bold mb-2">Airport Meet &amp; Greet</h3>
                <p class="text-on-surface-variant font-body leading-relaxed text-sm">Your driver meets you in the arrivals/baggage collection area with a Tropic Wings sign. No searching, no stress — just walk out and you're on your way.</p>
              </div>
            </div>
            <div class="flex gap-6">
              <div class="w-14 h-14 rounded-full bg-primary-container/20 flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-primary">schedule</span>
              </div>
              <div>
                <h3 class="text-lg font-headline font-bold mb-2">Fixed Schedules, Multiple Daily Departures</h3>
                <p class="text-on-surface-variant font-body leading-relaxed text-sm">Our coach runs are timed around flight arrivals so you're never left waiting long. Book ahead and your seat is guaranteed.</p>
              </div>
            </div>
            <div class="flex gap-6">
              <div class="w-14 h-14 rounded-full bg-secondary-container/50 flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-on-secondary-container">family_restroom</span>
              </div>
              <div>
                <h3 class="text-lg font-headline font-bold mb-2">Families, Groups, Solo Travellers</h3>
                <p class="text-on-surface-variant font-body leading-relaxed text-sm">Reduced fares for children aged 2–11, free travel for infants. Luggage included. Easy online booking with instant confirmation.</p>
              </div>
            </div>
          </div>
          <div class="mt-10 flex gap-4">
            <a href="/transfers" class="action-pill-gradient text-on-primary px-8 py-4 rounded-full font-headline font-bold flex items-center gap-2 shadow-lg shadow-primary/20 hover:scale-[1.02] transition-transform">
              Book Seat in Coach <span class="material-symbols-outlined text-sm">arrow_forward</span>
            </a>
            <a href="/private-transfer" class="px-8 py-4 rounded-full font-headline font-bold border-2 border-primary text-primary hover:bg-primary hover:text-on-primary transition-all">
              Private Transfer
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-surface-container-low py-24">
    <div class="max-w-4xl mx-auto px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-headline font-black tracking-tighter text-on-surface mb-4">Common Questions</h2>
        <p class="text-on-surface-variant font-body text-lg">Everything you need to know before you book.</p>
      </div>
      <div class="space-y-4">
        <div class="bg-surface-container-lowest rounded-xl p-8">
          <h3 class="font-headline font-bold text-lg mb-3">How do I get picked up at Cairns Airport?</h3>
          <p class="text-on-surface-variant font-body text-sm leading-relaxed">Your driver will meet you in the arrivals/baggage collection area holding a Tropic Wings Transfers sign. Once your group is assembled, you'll depart for Port Douglas.</p>
        </div>
        <div class="bg-surface-container-lowest rounded-xl p-8">
          <h3 class="font-headline font-bold text-lg mb-3">What if my flight is delayed?</h3>
          <p class="text-on-surface-variant font-body text-sm leading-relaxed">We monitor flight arrivals. If your flight is delayed, contact our team and we'll move you to the next available departure at no extra cost.</p>
        </div>
        <div class="bg-surface-container-lowest rounded-xl p-8">
          <h3 class="font-headline font-bold text-lg mb-3">Are child fares available?</h3>
          <p class="text-on-surface-variant font-body text-sm leading-relaxed">Yes — children aged 2–11 travel at a reduced fare. Infants under 2 travel free of charge (on lap).</p>
        </div>
        <div class="bg-surface-container-lowest rounded-xl p-8">
          <h3 class="font-headline font-bold text-lg mb-3">What's the difference between Seat in Coach and Private Transfer?</h3>
          <p class="text-on-surface-variant font-body text-sm leading-relaxed">Seat in Coach is a shared scheduled service — great value for solo travellers, couples, and families. Private Transfer is exclusively for your group in a fully electric VW ID Buzz — no other passengers, no stops, direct door-to-door.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CLOSING CTA -->
  <section class="relative overflow-hidden bg-primary py-24 px-8">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute -right-20 top-0 w-[500px] h-[500px] rounded-full bg-secondary-fixed"></div>
      <div class="absolute -left-20 bottom-0 w-96 h-96 rounded-full bg-white"></div>
    </div>
    <div class="relative max-w-3xl mx-auto text-center">
      <h2 class="text-4xl md:text-5xl font-headline font-black tracking-tighter text-white mb-4">Ready to book your transfer?</h2>
      <p class="text-white/75 font-body text-lg mb-10">Seats fill fast in peak season — lock in yours now. Instant confirmation, easy cancellation.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/transfers" class="bg-secondary-fixed text-on-secondary-fixed px-10 py-4 rounded-full font-headline font-bold text-lg hover:scale-[1.02] transition-transform shadow-xl">
          Book Seat in Coach
        </a>
        <a href="/private-transfer" class="bg-white/10 border-2 border-white/30 text-white px-10 py-4 rounded-full font-headline font-bold text-lg hover:bg-white/20 transition-all">
          Private Transfer
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
