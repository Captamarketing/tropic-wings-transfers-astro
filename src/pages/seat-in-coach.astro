---
import BaseLayout from '../layouts/BaseLayout.astro';
import { timetableCNS, timetablePD } from '../data/timetables';

const BOOKING_URL = "https://app.respax.com/public/tw?site=TWAIRPORT&tourCode=AIRPORTCNPD";

const schema = [
  {
    "@type": "Service",
    "name": "Seat in Coach — Cairns Airport to Port Douglas Scheduled Transfer",
    "description": "Shared scheduled coach transfers between Cairns Airport (CNS) and Port Douglas, Queensland. Airport meet and greet included. Multiple daily departures. Air-conditioned coaches operated by Tropic Wings.",
    "provider": { "@type": "TransportationCompany", "name": "Tropic Wings Transfers", "url": "https://transfers.tropicwings.com.au" },
    "serviceType": "Scheduled Airport Shuttle",
    "areaServed": { "@type": "Place", "name": "Cairns Airport to Port Douglas, Queensland, Australia" },
    "offers": { "@type": "Offer", "priceCurrency": "AUD", "availability": "https://schema.org/InStock", "url": BOOKING_URL },
    "additionalProperty": [
      { "@type": "PropertyValue", "name": "Route", "value": "Cairns Airport (CNS) to Port Douglas via Captain Cook Highway" },
      { "@type": "PropertyValue", "name": "Distance", "value": "Approximately 70km" },
      { "@type": "PropertyValue", "name": "Duration", "value": "Approximately 75 minutes" },
      { "@type": "PropertyValue", "name": "Frequency", "value": "Multiple daily departures" }
    ]
  },
  {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Tropic Wings Transfers", "item": "https://transfers.tropicwings.com.au" },
      { "@type": "ListItem", "position": 2, "name": "Seat in Coach", "item": "https://transfers.tropicwings.com.au/seat-in-coach" }
    ]
  },
  {
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How many coach departures are there from Cairns Airport to Port Douglas each day?", "acceptedAnswer": { "@type": "Answer", "text": "Tropic Wings operates multiple daily Seat in Coach departures between Cairns Airport and Port Douglas, timed around scheduled flight arrivals." } },
      { "@type": "Question", "name": "Is luggage included in the coach transfer from Cairns Airport to Port Douglas?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — one standard suitcase and one carry-on bag per passenger at no extra charge." } },
      { "@type": "Question", "name": "Do children get a discounted fare on the Cairns to Port Douglas coach?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Children aged 2–11 travel at a reduced fare. Infants under 2 travel free of charge (on lap)." } },
      { "@type": "Question", "name": "Does the coach stop at Palm Cove on the way to Port Douglas?", "acceptedAnswer": { "@type": "Answer", "text": "Some departures include a Palm Cove stop. Non-stop services take approximately 75 minutes; services with a Palm Cove stop take approximately 90 minutes." } }
    ]
  }
];

---

<BaseLayout
  title="Seat in Coach — Cairns Airport to Port Douglas | Tropic Wings"
  description="Affordable scheduled coach transfers between Cairns Airport and Port Douglas with Tropic Wings. Multiple daily departures, airport meet & greet, luggage included. Book online."
  canonical="/seat-in-coach"
  schema={schema}
>

  <!-- HERO -->
  <header class="relative h-[500px] overflow-hidden hero-clip">
    <div class="absolute inset-0">
      <img class="w-full h-full object-cover"
        src="https://tropicwings.com.au/wp-content/uploads/2024/09/4.jpg"
        alt="Modern air-conditioned coach for Cairns Airport to Port Douglas transfers — Tropic Wings"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-black/65 via-black/30 to-transparent"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-8 h-full flex flex-col justify-center">
      <nav class="text-white/60 text-xs font-label mb-6 flex items-center gap-2">
        <a href="/" class="hover:text-secondary-fixed transition-colors">Tropic Wings Transfers</a>
        <span class="material-symbols-outlined text-sm">chevron_right</span>
        <span class="text-white">Seat in Coach</span>
      </nav>
      <h1 class="text-5xl md:text-6xl font-headline font-extrabold text-white leading-tight tracking-normal mb-4">
        Seat in Coach<br/><span class="text-white/70 text-3xl md:text-4xl">Cairns Airport to Port Douglas</span>
      </h1>
      <p class="text-white/80 font-body text-lg max-w-xl mb-8">The smart, affordable way to travel between Cairns Airport and Port Douglas. Book a seat on our daily scheduled service — we handle everything from arrivals to your accommodation door.</p>
      <a href={BOOKING_URL} class="inline-flex items-center gap-3 action-pill-gradient text-on-primary px-10 py-4 rounded-full font-headline font-bold text-lg shadow-xl hover:scale-[1.02] transition-transform w-fit">
        View Timetable &amp; Book <span class="material-symbols-outlined">arrow_forward</span>
      </a>
    </div>
  </header>

  <!-- INTRO -->
  <section class="max-w-4xl mx-auto px-8 py-16 text-center">
    <h2 class="text-3xl font-headline font-black tracking-tighter text-on-surface mb-6">The reliable daily transfer between Cairns Airport and Port Douglas</h2>
    <p class="text-on-surface-variant font-body text-lg leading-relaxed">Tropic Wings has been operating in tropical North Queensland since 1981. Our Seat in Coach transfer service runs multiple times daily between Cairns Airport (CNS) and Port Douglas — timed around flight arrivals so you're never waiting long. Your driver meets you in the arrivals hall, you settle into a modern air-conditioned coach, and you're in Port Douglas in around 75 minutes.</p>
  </section>

  <!-- TIMETABLES -->
  <section class="max-w-5xl mx-auto px-8 py-8 pb-20">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">

      <div>
        <h2 class="text-2xl font-headline font-black tracking-tighter text-on-surface mb-6 flex items-center gap-3">
          <span class="material-symbols-outlined text-primary">flight_land</span>
          Cairns Airport → Port Douglas
        </h2>
        <div class="bg-surface-container-lowest rounded-xl overflow-hidden shadow-sm">
          <div class="bg-primary px-6 py-3 grid grid-cols-3 gap-4">
            <p class="text-on-primary text-xs font-black font-label uppercase tracking-widest">Departs CNS</p>
            <p class="text-on-primary text-xs font-black font-label uppercase tracking-widest">Arrives PD</p>
            <p class="text-on-primary text-xs font-black font-label uppercase tracking-widest">Type</p>
          </div>
          <div class="divide-y divide-surface-container-high">
            {timetableCNS.map((row) => (
              <div class={`px-6 py-4 grid grid-cols-3 gap-4 hover:bg-surface-container-low transition-colors ${row.popular ? 'bg-secondary-fixed/10' : ''}`}>
                <p class="font-headline font-bold">{row.depart}</p>
                <p class="text-on-surface-variant font-body text-sm">{row.arrive}</p>
                <span class={`text-xs px-2 py-0.5 rounded-full font-label w-fit ${row.popular ? 'bg-primary text-on-primary font-black' : row.type === 'Non-stop' ? 'bg-secondary-fixed text-on-secondary-fixed font-black' : 'bg-surface-container text-on-surface-variant'}`}>
                  {row.popular ? 'Popular' : row.type}
                </span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <div>
        <h2 class="text-2xl font-headline font-black tracking-tighter text-on-surface mb-6 flex items-center gap-3">
          <span class="material-symbols-outlined text-primary">flight_takeoff</span>
          Port Douglas → Cairns Airport
        </h2>
        <div class="bg-surface-container-lowest rounded-xl overflow-hidden shadow-sm">
          <div class="bg-primary-container px-6 py-3 grid grid-cols-3 gap-4">
            <p class="text-on-primary-container text-xs font-black font-label uppercase tracking-widest">Departs PD</p>
            <p class="text-on-primary-container text-xs font-black font-label uppercase tracking-widest">Arrives CNS</p>
            <p class="text-on-primary-container text-xs font-black font-label uppercase tracking-widest">Type</p>
          </div>
          <div class="divide-y divide-surface-container-high">
            {timetablePD.map((row) => (
              <div class={`px-6 py-4 grid grid-cols-3 gap-4 hover:bg-surface-container-low transition-colors ${row.popular ? 'bg-secondary-fixed/10' : ''}`}>
                <p class="font-headline font-bold">{row.depart}</p>
                <p class="text-on-surface-variant font-body text-sm">{row.arrive}</p>
                <span class={`text-xs px-2 py-0.5 rounded-full font-label w-fit ${row.popular ? 'bg-primary text-on-primary font-black' : row.type === 'Non-stop' ? 'bg-secondary-fixed text-on-secondary-fixed font-black' : 'bg-surface-container text-on-surface-variant'}`}>
                  {row.popular ? 'Popular' : row.type}
                </span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
    <p class="text-on-surface-variant text-xs font-body mt-6 text-center">* Timetables indicative — confirm exact times at booking. Allow at least 3 hours before your departure flight when booking a return.</p>
  </section>

  <!-- PRICING -->
  <section class="bg-surface-container-low py-20 px-8">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl font-headline font-black tracking-tighter text-on-surface mb-10 text-center">Fares</h2>
      <div class="bg-surface-container-lowest rounded-xl overflow-hidden shadow-sm">
        <div class="bg-primary px-8 py-4">
          <p class="text-on-primary font-headline font-bold">Seat in Coach — Per Person</p>
        </div>
        <div class="divide-y divide-surface-container-high">
          <div class="px-8 py-5 flex justify-between items-center">
            <p class="font-headline font-bold">Adult <span class="text-on-surface-variant font-body font-normal text-sm">(12+ years)</span></p>
            <div class="text-right">
              <p class="text-lg font-headline font-extrabold text-primary">See booking for pricing</p>
              <p class="text-sm text-on-surface-variant font-body">One way &amp; return (AUD)</p>
            </div>
          </div>
          <div class="px-8 py-5 flex justify-between items-center">
            <p class="font-headline font-bold">Child <span class="text-on-surface-variant font-body font-normal text-sm">(2–11 years)</span></p>
            <div class="text-right">
              <p class="text-lg font-headline font-extrabold text-primary">Reduced fare</p>
              <p class="text-sm text-on-surface-variant font-body">One way &amp; return (AUD)</p>
            </div>
          </div>
          <div class="px-8 py-5 flex justify-between items-center bg-surface-container-low">
            <p class="font-headline font-bold">Infant <span class="text-on-surface-variant font-body font-normal text-sm">(under 2 years)</span></p>
            <p class="text-2xl font-headline font-extrabold text-secondary">Free</p>
          </div>
        </div>
      </div>
      <p class="text-center text-on-surface-variant text-sm font-body mt-6">All fares include luggage allowance (1 suitcase + 1 carry-on) and airport meet &amp; greet.</p>
      <div class="text-center mt-8">
        <a href={BOOKING_URL} class="inline-flex items-center gap-3 action-pill-gradient text-on-primary px-12 py-4 rounded-full font-headline font-bold text-lg shadow-xl hover:scale-[1.02] transition-transform">
          Book Your Seat <span class="material-symbols-outlined">arrow_forward</span>
        </a>
      </div>
    </div>
  </section>

  <!-- PRIVATE UPSELL -->
  <section class="bg-primary py-16 px-8 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute -right-10 -top-10 w-80 h-80 rounded-full bg-secondary-fixed"></div>
    </div>
    <div class="relative max-w-4xl mx-auto flex flex-col md:flex-row items-center justify-between gap-8">
      <div>
        <p class="text-white/60 text-xs font-label uppercase tracking-widest mb-2">Travelling as a group?</p>
        <h3 class="text-3xl font-headline font-black tracking-tighter text-white mb-3">Upgrade to Private Transfer</h3>
        <p class="text-white/75 font-body">Just your group in a fully electric VW ID Buzz. No other passengers, no stops. Often comparable in price to individual coach fares for groups.</p>
      </div>
      <a href="/private-transfer" class="shrink-0 bg-secondary-fixed text-on-secondary-fixed px-10 py-4 rounded-full font-headline font-bold hover:scale-[1.02] transition-transform shadow-xl whitespace-nowrap">
        View Private Transfer
      </a>
    </div>
  </section>

</BaseLayout>
